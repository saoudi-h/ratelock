        "@tala-tools/eslint": "0.1.0",
        "@tala-tools/prettier": "0.0.2",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "tailwindcss": "^4.2.4",
        "tw-animate-css": "^1.4.0"
