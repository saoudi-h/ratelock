{
    "name": "@ratelock/postgres",
    "description": "PostgreSQL storage backend for RateLock rate limiting system",
    "version": "0.2.0",
    "homepage": "https://github.com/saoudi-h/ratelock",
    "bugs": {
        "url": "https://github.com/saoudi-h/ratelock/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saoudi-h/ratelock.git",
        "directory": "packages/postgres"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --max-warnings 0 --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "test": "vitest --exclude \"**/*.integration.test.ts\"",
        "test:ui": "vitest --exclude \"**/*.integration.test.ts\" --ui",
        "test:run": "vitest run --exclude \"**/*.integration.test.ts\"",
        "test:coverage": "vitest run --coverage",
        "test:coverage:dev": "pnpm run docker:up && vitest run --coverage && pnpm run docker:down",
        "test:integration": "pnpm run docker:up && vitest run __integration__/integration.test.ts --config vitest.integration.config.ts; status=$?; pnpm run docker:down; exit $status",
        "typecheck": "tsgo --noEmit",
        "clean": "rimraf dist node_modules .turbo",
        "docker:up": "docker-compose --env-file .env.test -f docker-compose.test.yml up -d --wait",
        "docker:down": "docker-compose --env-file .env.test -f docker-compose.test.yml down",
        "prepack": "tsdown",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@ratelock/core": "workspace:*"
    },
    "peerDependencies": {
        "pg": ">=8.0.0",
        "postgres": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "postgres": {
            "optional": true
        },
        "pg": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@ratelock/test-utils": "workspace:*",
        "@ratelock/vitest": "workspace:*",
        "@tala-tools/eslint": "0.1.4",
        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^26.1.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-v8": "^4.1.9",
        "dotenv": "^17.4.2",
        "pg": "^8.22.0",
        "postgres": ">=3.0.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=20",
        "bun": ">=1.1"
    },
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "license": "MIT",
    "keywords": [
        "rate-limit",
        "postgres",
        "postgresql",
        "sliding-window",
        "fixed-window",
        "token-bucket",
        "bun",
        "cross-runtime"
    ],
    "module": "./dist/index.mjs"
}
