{
    "name": "@ratelock/local",
    "description": "In-memory storage backend for RateLock rate limiting system",
    "version": "0.2.0",
    "homepage": "https://github.com/saoudi-h/ratelock",
    "bugs": {
        "url": "https://github.com/saoudi-h/ratelock/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saoudi-h/ratelock.git",
        "directory": "packages/local"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --max-warnings 0 --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "clean": "rimraf dist .turbo node_modules",
        "typecheck": "tsgo --noEmit",
        "prepack": "tsdown",
        "pre-commit": "lint-staged"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@ratelock/test-utils": "workspace:*",
        "@ratelock/vitest": "workspace:*",
        "@tala-tools/eslint": "0.1.2",
        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^25.9.0",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "@ratelock/core": "workspace:*"
    },
    "keywords": [
        "@ratelock",
        "storage",
        "memory",
        "rate-locking",
        "rate-lock",
        "ratelimit",
        "typescript",
        "bun",
        "cross-runtime"
    ],
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "license": "MIT",
    "engines": {
        "node": ">=22",
        "bun": ">=1.1"
    },
    "module": "./dist/index.mjs"
}
