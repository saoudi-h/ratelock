{
    "name": "@ratelock/test-utils",
    "version": "0.1.2",
    "private": true,
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./contracts": {
            "import": "./dist/contracts/index.mjs",
            "require": "./dist/contracts/index.cjs"
        },
        "./contracts/limiter.contract": {
            "import": "./dist/contracts/limiter.contract.mjs",
            "require": "./dist/contracts/limiter.contract.cjs"
        },
        "./contracts/storage.contract": {
            "import": "./dist/contracts/storage.contract.mjs",
            "require": "./dist/contracts/storage.contract.cjs"
        },
        "./helpers": {
            "import": "./dist/helpers/index.mjs",
            "require": "./dist/helpers/index.cjs"
        },
        "./helpers/random": {
            "import": "./dist/helpers/random.mjs",
            "require": "./dist/helpers/random.cjs"
        },
        "./helpers/time": {
            "import": "./dist/helpers/time.mjs",
            "require": "./dist/helpers/time.cjs"
        },
        "./mocks": {
            "import": "./dist/mocks/index.mjs",
            "require": "./dist/mocks/index.cjs"
        },
        "./mocks/clock.mock": {
            "import": "./dist/mocks/clock.mock.mjs",
            "require": "./dist/mocks/clock.mock.cjs"
        },
        "./mocks/logger.mock": {
            "import": "./dist/mocks/logger.mock.mjs",
            "require": "./dist/mocks/logger.mock.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --max-warnings 0 --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "clean": "rimraf node_modules dist",
        "typecheck": "tsgo --noEmit",
        "test": "vitest",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@ratelock/core": "workspace:*"
    },
    "devDependencies": {
        "@tala-tools/eslint": "0.1.0",
        "@tala-tools/prettier": "0.0.2",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "chai": "^6.2.2",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=18.17.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "module": "./dist/index.mjs"
}
