{
    "name": "@ratelock/test-utils",
    "version": "0.1.2",
    "private": true,
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./contracts": {
            "import": "./dist/contracts/index.mjs",
            "require": "./dist/contracts/index.cjs"
        },
        "./contracts/fixed-window": {
            "import": "./dist/contracts/fixed-window.mjs",
            "require": "./dist/contracts/fixed-window.cjs"
        },
        "./contracts/individual-fixed-window": {
            "import": "./dist/contracts/individual-fixed-window.mjs",
            "require": "./dist/contracts/individual-fixed-window.cjs"
        },
        "./contracts/sliding-window": {
            "import": "./dist/contracts/sliding-window.mjs",
            "require": "./dist/contracts/sliding-window.cjs"
        },
        "./contracts/token-bucket": {
            "import": "./dist/contracts/token-bucket.mjs",
            "require": "./dist/contracts/token-bucket.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --max-warnings 0 --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "clean": "rimraf node_modules dist",
        "typecheck": "tsgo --noEmit",
        "test": "vitest",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@ratelock/core": "workspace:*"
    },
    "devDependencies": {
        "@tala-tools/eslint": "0.1.0",
        "@tala-tools/prettier": "0.0.2",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "chai": "^6.2.2",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=18.17.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "module": "./dist/index.mjs"
}
