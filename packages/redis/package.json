{
    "name": "@ratelock/redis",
    "version": "0.2.0",
    "description": "Redis storage backend for RateLock rate limiting system",
    "keywords": [
        "rate-limit",
        "rate-limiting",
        "redis",
        "throttle",
        "api-rate-limit",
        "sliding-window",
        "fixed-window",
        "token-bucket",
        "bun",
        "cross-runtime"
    ],
    "homepage": "https://github.com/saoudi-h/ratelock",
    "bugs": {
        "url": "https://github.com/saoudi-h/ratelock/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saoudi-h/ratelock.git",
        "directory": "packages/redis"
    },
    "license": "MIT",
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest --exclude \"**/*.integration.test.ts\"",
        "test:ui": "vitest --exclude \"**/*.integration.test.ts\" --ui",
        "test:run": "vitest run --exclude \"**/*.integration.test.ts\"",
        "test:coverage": "vitest run --coverage",
        "test:coverage:dev": "pnpm run docker:up && vitest run --coverage && pnpm run docker:down",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --check .",
        "typecheck": "tsgo --noEmit",
        "clean": "rimraf dist .turbo node_modules",
        "prepack": "tsdown",
        "docker:up": "docker-compose --env-file .env.test -f docker-compose.test.yml up -d --wait",
        "docker:down": "docker-compose --env-file .env.test -f docker-compose.test.yml down",
        "test:integration": "pnpm run docker:up && vitest run --config vitest.integration.config.ts; status=$?; pnpm run docker:down; exit $status",
        "pre-commit": "lint-staged"
    },
    "peerDependencies": {
        "ioredis": "^5.0.0",
        "redis": "^4.0.0 || ^5.0.0"
    },
    "peerDependenciesMeta": {
        "redis": {
            "optional": true
        },
        "ioredis": {
            "optional": true
        }
    },
    "dependencies": {
        "@ratelock/core": "workspace:*"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@ratelock/test-utils": "workspace:*",
        "@ratelock/vitest": "workspace:*",
        "@tala-tools/eslint": "0.1.2",
        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/node": "^25.9.0",
        "@vitest/coverage-v8": "^4.1.6",
        "dotenv": "^17.4.2",
        "ioredis": "^5.10.1",
        "luamin": "^1.0.4",
        "redis": "^5.12.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "engines": {
        "node": ">=22",
        "bun": ">=1.1"
    },
    "publishConfig": {
        "access": "public"
    },
    "module": "./dist/index.mjs"
}
