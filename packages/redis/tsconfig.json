{
    "extends": "@tala-tools/tsconfig/base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vitest", "node"]
    },
    "include": [
        "./src/**/*",
        "tsdown.config.ts",
        "vitest.config.ts",
        "./examples/**/*",
        "./types",
        "./scripts",
        "lint-staged.config.mjs"
    ],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo"]
}
